<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
  <%= form_with(model: [:admin, article], local: true, class: "space-y-6") do |form| %>
    <% if article.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg" role="alert">
        <div class="font-semibold mb-2"><%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:</div>
        <ul class="list-disc list-inside space-y-1">
          <% article.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <div>
      <%= form.label :title, "Title", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
    </div>
    <div>
      <%= form.label :published, class: "inline-flex items-center gap-3 cursor-pointer" do %>
        <%= form.check_box :published, class: "w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
        <span class="text-sm font-medium text-gray-700">Published</span>
      <% end %>
    </div>
    <div>
      <%= form.label :user_ids, "Authors", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div class="flex flex-wrap gap-2 p-4 border border-gray-300 rounded-lg">
        <% User.all.each do |user| %>
          <label class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-gray-300 cursor-pointer has-checked:bg-blue-50 has-checked:border-blue-500 has-checked:text-blue-700 has-checked:[&>span]:bg-blue-500 hover:bg-gray-50 transition-colors text-sm">
            <%= check_box_tag "article[user_ids][]", user.id, article.user_ids.include?(user.id), class: "sr-only" %>
            <span class="inline-block w-2 h-2 rounded-full bg-gray-300"></span>
            <%= user.email_address %>
          </label>
        <% end %>
      </div>
    </div>
    <div>
      <%= form.label :body, "Content", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.rich_text_area :body, class: "w-full min-h-[300px] px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
    </div>
    <div class="flex items-center justify-between pt-4 border-t border-gray-200">
      <%= link_to "Cancel", admin_articles_path, class: "px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors font-medium" %>
      <%= form.submit article.new_record? ? "Create Article" : "Update Article",
          class: "px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors font-medium cursor-pointer" %>
    </div>
  <% end %>
</div>
