<div class="admin-page py-6">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render "admin/shared/form_page_header",
        title: "Edit Article",
        description: "Update article details",
        back_path: admin_articles_path %>
    <%= render "form", article: @article %>
    <div class="mt-6">
      <%= button_to "Delete Article",
          admin_article_path(@article),
          method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete this article?" },
          class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors font-medium" %>
    </div>
  </div>
</div>
