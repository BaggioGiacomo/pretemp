<section class="admin-page py-4">
  <div class="mb-6">
    <p class="text-xs uppercase tracking-[0.14em] text-blue-600/80 font-semibold">Control Center</p>
    <h1 class="text-3xl font-bold text-slate-900">Admin Dashboard</h1>
    <p class="mt-1 text-sm text-slate-600">Overview of activity and access management for the PRETEMP administration area.</p>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
    <div class="admin-surface p-6">
      <p class="text-xs uppercase tracking-wide text-slate-500">Total Admins</p>
      <p class="mt-3 text-4xl font-bold text-blue-700"><%= User.count %></p>
      <p class="mt-2 text-xs text-slate-500">Active user accounts with admin permissions</p>
    </div>
    <div class="admin-surface p-6">
      <p class="text-xs uppercase tracking-wide text-slate-500">Pending Invitations</p>
      <p class="mt-3 text-4xl font-bold text-amber-600"><%= Invitation.pending.count %></p>
      <p class="mt-2 text-xs text-slate-500">Invitations sent but not accepted yet</p>
    </div>
    <div class="admin-surface p-6">
      <p class="text-xs uppercase tracking-wide text-slate-500">Current Session</p>
      <p class="mt-3 text-lg font-semibold text-slate-900">Welcome back</p>
      <p class="mt-1 text-sm text-slate-600 truncate"><%= current_user.email_address %></p>
    </div>
  </div>
</section>
