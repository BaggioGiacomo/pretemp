<div class="admin-surface p-6">
  <%= form_with(model: [:admin, @didattica_section, didattica_item], local: true, multipart: true, class: "space-y-6") do |form| %>
    <% if didattica_item.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg" role="alert">
        <div class="font-semibold mb-2"><%= pluralize(didattica_item.errors.count, "error") %>:</div>
        <ul class="list-disc list-inside space-y-1">
          <% didattica_item.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <div>
      <%= form.label :title, "Title", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
    </div>
    <div>
      <%= form.label :url, "URL (optional if uploading a PDF)", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.url_field :url, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors", placeholder: "https://..." %>
      <p class="mt-1 text-xs text-gray-500">Leave blank to use the uploaded PDF below.</p>
    </div>
    <div>
      <%= form.label :pdf, "PDF (optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <% if didattica_item.pdf.attached? %>
        <div class="mb-2 flex items-center gap-3 p-3 bg-amber-50 border border-amber-200 rounded-lg">
          <span class="text-sm text-amber-900"><%= didattica_item.pdf.filename %></span>
          <%= link_to "Open", rails_blob_path(didattica_item.pdf, only_path: true), target: "_blank", rel: "noopener", class: "text-sm text-blue-600 hover:underline" %>
          <label class="ml-auto inline-flex items-center gap-2 text-sm text-red-700">
            <%= form.check_box :remove_pdf, { checked: false }, "1", "0" %>
            Remove PDF
          </label>
        </div>
      <% end %>
      <%= form.file_field :pdf, accept: "application/pdf", class: "w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
    </div>
    <div>
      <%= form.label :position, "Position", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :position, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
    </div>
    <div class="flex items-center justify-between pt-4 border-t border-gray-200">
      <%= link_to "Cancel", admin_didattica_section_didattica_items_path(@didattica_section), class: "px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors font-medium" %>
      <%= form.submit didattica_item.new_record? ? "Create Item" : "Update Item",
          class: "admin-btn-primary cursor-pointer" %>
    </div>
  <% end %>
</div>
