<div class="admin-page py-6">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render "admin/shared/form_page_header",
        title: "Update item",
        description: "Update the item in #{@didattica_section.name}",
        back_path: admin_didattica_section_didattica_items_path(@didattica_section) %>
    <%= render "form", didattica_item: @didattica_item %>
    <div class="mt-6">
      <%= button_to "Delete Item",
          admin_didattica_section_didattica_item_path(@didattica_section, @didattica_item),
          method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete this item?" },
          class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors font-medium" %>
    </div>
  </div>
</div>
