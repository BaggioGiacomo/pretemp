<div class="admin-page py-6">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render "admin/shared/form_page_header",
        title: "Edit Section",
        description: "Update the section details",
        back_path: admin_didattica_sections_path %>
    <%= render "form", didattica_section: @didattica_section %>
    <div class="mt-6">
      <%= button_to "Delete Section",
          admin_didattica_section_path(@didattica_section),
          method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete this section and all its items?" },
          class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors font-medium" %>
    </div>
  </div>
</div>
