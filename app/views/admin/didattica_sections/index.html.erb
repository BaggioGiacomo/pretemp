<div class="admin-page py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Didattica</h1>
          <p class="mt-1 sm:mt-2 text-gray-600 text-sm">Manage the sections of the Didattica page and their items</p>
        </div>
        <%= link_to "New Section", new_admin_didattica_section_path, class: "admin-btn-primary text-center" %>
      </div>
    </div>
    <div class="admin-surface overflow-hidden">
      <% if @didattica_sections.any? %>
        <div class="divide-y divide-gray-200">
          <% @didattica_sections.each do |section| %>
            <div class="p-4 sm:p-6 hover:bg-gray-50 transition-colors">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <%= link_to edit_admin_didattica_section_path(section), class: "flex-1 min-w-0" do %>
                  <div>
                    <h3 class="text-base sm:text-lg font-semibold text-gray-900 hover:text-blue-600 transition-colors">
                      <%= section.name %>
                    </h3>
                    <% if section.description.present? %>
                      <p class="mt-1 text-sm text-gray-500"><%= truncate(section.description, length: 120) %></p>
                    <% end %>
                    <div class="mt-2 flex flex-wrap items-center gap-2 sm:gap-4 text-sm text-gray-500">
                      <span class="px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                        <%= pluralize(section.didattica_items.count, "item") %>
                      </span>
                      <span class="text-xs text-gray-400">Position: <%= section.position %></span>
                    </div>
                  </div>
                <% end %>
                <div class="flex items-center gap-2 sm:gap-3 sm:ml-4">
                  <%= link_to "Items", admin_didattica_section_didattica_items_path(section), class: "px-3 sm:px-4 py-2 text-sm text-blue-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-colors font-medium" %>
                  <%= button_to admin_didattica_section_path(section),
                      method: :delete,
                      data: { turbo_confirm: "Are you sure you want to delete this section and all its items?" },
                      class: "px-3 sm:px-4 py-2 text-sm text-red-600 hover:text-red-700 hover:bg-red-50 rounded-lg transition-colors font-medium" do %>
                    Delete
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-12 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No sections</h3>
          <p class="mt-1 text-sm text-gray-500">Start by creating a new section.</p>
          <div class="mt-6">
            <%= link_to "New Section", new_admin_didattica_section_path, class: "admin-btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
