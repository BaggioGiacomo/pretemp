<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-6">
      <div class="flex items-center gap-4">
        <%= link_to admin_forecast_forecast_updates_path(@forecast), class: "text-gray-600 hover:text-gray-900 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
        <% end %>
        <h1 class="text-3xl font-bold text-gray-900">Edit Update</h1>
      </div>
      <p class="mt-2 text-gray-600">Update details for: <strong><%= @forecast.title %></strong></p>
    </div>
    <%= render "form", forecast_update: @forecast_update %>
    <div class="mt-6">
      <%= button_to "Delete Update",
          admin_forecast_forecast_update_path(@forecast, @forecast_update),
          method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete this update?" },
          class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors font-medium" %>
    </div>
  </div>
</div>
