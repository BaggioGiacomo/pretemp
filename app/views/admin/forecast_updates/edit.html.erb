<div class="admin-page py-6">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render "admin/shared/form_page_header",
        title: "Edit Update",
        description: "Update details for #{@forecast.title}",
        back_path: admin_forecast_forecast_updates_path(@forecast) %>
    <%= render "form", forecast_update: @forecast_update %>
    <div class="mt-6">
      <%= button_to "Delete Update",
          admin_forecast_forecast_update_path(@forecast, @forecast_update),
          method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete this update?" },
          class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors font-medium" %>
    </div>
  </div>
</div>
