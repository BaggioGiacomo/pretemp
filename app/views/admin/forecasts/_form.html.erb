<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
  <%= form_with(model: [:admin, forecast], local: true, class: "space-y-6") do |form| %>
    <% if forecast.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg" role="alert">
        <div class="font-semibold mb-2"><%= pluralize(forecast.errors.count, "error") %> prohibited this forecast from being saved:</div>
        <ul class="list-disc list-inside space-y-1">
          <% forecast.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <div>
      <%= form.label :date, "Date", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.date_field :date, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors", value: forecast.date || Date.today %>
    </div>
    <div>
      <%= form.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :status,
          options_for_select([["Draft", "draft"], ["Published", "published"], ["Archived", "archived"]], forecast.status || "published"),
          {},
          class: "w-full px-4 py-2 pr-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors appearance-none bg-no-repeat bg-[length:16px_16px] bg-[position:right_12px_center] bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2020%2020%22%20fill%3D%22%236b7280%22%3E%3Cpath%20fill-rule%3D%22evenodd%22%20d%3D%22M5.23%207.21a.75.75%200%20011.06.02L10%2011.168l3.71-3.938a.75.75%200%20111.08%201.04l-4.25%204.5a.75.75%200%2001-1.08%200l-4.25-4.5a.75.75%200%2001.02-1.06z%22%20clip-rule%3D%22evenodd%22%2F%3E%3C%2Fsvg%3E')]" %>
    </div>
    <div>
      <%= form.label :risk_level, "Risk Level", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :risk_level,
          options_for_select(Forecast.risk_levels.map.with_index { |(key, value), index| ["#{key.titleize} (#{index})", key] }, forecast.risk_level),
          { include_blank: "Nessuno" },
          class: "w-full px-4 py-2 pr-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors appearance-none bg-no-repeat bg-[length:16px_16px] bg-[position:right_12px_center] bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2020%2020%22%20fill%3D%22%236b7280%22%3E%3Cpath%20fill-rule%3D%22evenodd%22%20d%3D%22M5.23%207.21a.75.75%200%20011.06.02L10%2011.168l3.71-3.938a.75.75%200%20111.08%201.04l-4.25%204.5a.75.75%200%2001-1.08%200l-4.25-4.5a.75.75%200%2001.02-1.06z%22%20clip-rule%3D%22evenodd%22%2F%3E%3C%2Fsvg%3E')]" %>
    </div>
    <div>
      <%= form.label :user_ids, "Authors", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div class="flex flex-wrap gap-2 p-4 border border-gray-300 rounded-lg">
        <% User.all.each do |user| %>
          <label class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-gray-300 cursor-pointer has-checked:bg-blue-50 has-checked:border-blue-500 has-checked:text-blue-700 has-checked:[&>span]:bg-blue-500 hover:bg-gray-50 transition-colors text-sm">
            <%= check_box_tag "forecast[user_ids][]", user.id, forecast.user_ids.include?(user.id), class: "sr-only" %>
            <span class="inline-block w-2 h-2 rounded-full bg-gray-300"></span>
            <%= user.email_address %>
          </label>
        <% end %>
      </div>
    </div>
    <div data-controller="image-preview">
      <%= form.label :image, "Image", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <label class="flex flex-col items-center justify-center w-full h-40 border-2 border-dashed border-gray-300 rounded-lg cursor-pointer hover:border-blue-400 hover:bg-blue-50/50 transition-colors">
        <div class="flex flex-col items-center justify-center pt-5 pb-6">
          <svg class="w-8 h-8 mb-3 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
          </svg>
          <p class="mb-1 text-sm text-gray-500"><span class="font-semibold text-blue-600">Click to upload</span> or drag and drop</p>
          <p class="text-xs text-gray-400">PNG, JPG, GIF, WEBP</p>
        </div>
        <%= form.file_field :image, class: "hidden", accept: "image/*", data: { image_preview_target: "input", action: "change->image-preview#show" } %>
      </label>
      <div class="mt-4 <%= 'hidden' unless forecast.image.attached? %>" data-image-preview-target="preview">
        <% if forecast.image.attached? %>
          <%= image_tag forecast.image, class: "rounded-lg border border-gray-200 w-72", data: { image_preview_target: "previewImage" } %>
        <% else %>
          <img class="rounded-lg border border-gray-200 w-72" data-image-preview-target="previewImage" />
        <% end %>
      </div>
    </div>
    <div>
      <%= form.label :body, "Content", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.rich_text_area :body, class: "w-full min-h-[300px] px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
    </div>
    <div>
      <%= form.label :summary, "Summary", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.rich_text_area :summary, class: "w-full min-h-[300px] px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors", value: forecast.summary.body || Forecast::DEFAULT_SUMMARY %>
    </div>
    <div class="flex items-center justify-between pt-4 border-t border-gray-200">
      <%= link_to "Cancel", admin_forecasts_path, class: "px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors font-medium" %>
      <%= form.submit forecast.new_record? ? "Create Forecast" : "Update Forecast",
          class: "px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors font-medium" %>
    </div>
  <% end %>
</div>
