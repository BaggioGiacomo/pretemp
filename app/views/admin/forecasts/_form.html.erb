<div class="admin-surface p-6">
  <%= form_with(model: [:admin, forecast], local: true, class: "space-y-6", data: { controller: "admin-forecast-date" }) do |form| %>
    <% if forecast.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg" role="alert">
        <div class="font-semibold mb-2"><%= pluralize(forecast.errors.count, "error") %> prohibited this forecast from being saved:</div>
        <ul class="list-disc list-inside space-y-1">
          <% forecast.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <%# Tendenza Checkbox %>
    <div class="flex items-center gap-3 p-4 border border-gray-200 rounded-lg bg-gray-50">
      <label class="flex items-center gap-3 cursor-pointer flex-1">
        <%= form.check_box :tendenza, 
            { class: "w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500", 
              data: { "admin-forecast-date-target" => "checkbox", action: "change->admin-forecast-date#onTendenzaChange" } } %>
        <span class="text-sm font-medium text-gray-700">Tendenza?</span>
      </label>
      <span class="text-xs text-gray-500">Trend forecasts can only be set from day after tomorrow onwards</span>
    </div>
    <%# Date Picker %>
    <div class="relative"
         data-controller="date-picker"
         data-admin-forecast-date-target="datePickerContainer"
         data-date-picker-min-value="<%= forecast.tendenza? ? (Date.today + 2).to_s : Date.new(2015, 1, 1).to_s %>"
         data-date-picker-max-value="<%= (Date.today + 60).to_s %>"
         data-date-picker-placeholder-value="Seleziona una data">
      <label class="block text-sm font-medium text-gray-700 mb-2">Data</label>
      <%= form.hidden_field :date, value: forecast.date || Date.today,
          data: { date_picker_target: "input" } %>
      <button type="button"
              data-date-picker-target="trigger"
              data-action="click->date-picker#toggle"
        aria-haspopup="dialog" aria-expanded="false"
        class="w-full inline-flex items-center justify-between gap-2 rounded-xl border border-gray-300 bg-white px-4 py-2 text-sm text-left hover:border-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-colors">
        <span class="inline-flex items-center gap-2 min-w-0">
          <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <span data-date-picker-target="label" class="truncate text-gray-700">Seleziona una data</span>
        </span>
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <div data-date-picker-target="panel"
           class="hidden absolute z-30 mt-2 w-80 rounded-2xl border border-gray-200 bg-white shadow-lg p-3">
        <div class="flex items-center justify-between mb-3">
          <button type="button" data-action="click->date-picker#prevMonth"
            class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors" aria-label="Previous month">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <span data-date-picker-target="title" class="text-sm font-semibold text-gray-900"></span>
          <button type="button" data-action="click->date-picker#nextMonth"
            class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors" aria-label="Next month">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
        <div data-date-picker-target="grid" class="grid grid-cols-7 gap-1 mb-3"></div>
        <div class="pt-2 border-t border-gray-200 flex justify-between">
          <button type="button" data-action="click->date-picker#clear"
            class="text-xs font-medium text-gray-600 hover:text-gray-900 px-2 py-1 rounded hover:bg-gray-100 transition-colors">Cancella</button>
          <span class="text-xs text-gray-400">Click to select</span>
        </div>
      </div>
    </div>
    <div>
      <%= form.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :status,
          options_for_select([["Draft", "draft"], ["Published", "published"], ["Archived", "archived"]], forecast.status || "published"),
          {},
          class: "w-full px-4 py-2 pr-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors appearance-none bg-no-repeat bg-[length:16px_16px] bg-[position:right_12px_center] bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2020%2020%22%20fill%3D%22%236b7280%22%3E%3Cpath%20fill-rule%3D%22evenodd%22%20d%3D%22M5.23%207.21a.75.75%200%20011.06.02L10%2011.168l3.71-3.938a.75.75%200%20111.08%201.04l-4.25%204.5a.75.75%200%2001-1.08%200l-4.25-4.5a.75.75%200%2001.02-1.06z%22%20clip-rule%3D%22evenodd%22%2F%3E%3C%2Fsvg%3E')]" %>
    </div>
    <div>
      <%= form.label :risk_level, "Risk Level", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :risk_level,
          options_for_select(Forecast.risk_levels.map.with_index { |(key, value), index| ["#{key.titleize} (#{index})", key] }, forecast.risk_level),
          { include_blank: "Nessuno" },
          class: "w-full px-4 py-2 pr-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors appearance-none bg-no-repeat bg-[length:16px_16px] bg-[position:right_12px_center] bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2020%2020%22%20fill%3D%22%236b7280%22%3E%3Cpath%20fill-rule%3D%22evenodd%22%20d%3D%22M5.23%207.21a.75.75%200%20011.06.02L10%2011.168l3.71-3.938a.75.75%200%20111.08%201.04l-4.25%204.5a.75.75%200%2001-1.08%200l-4.25-4.5a.75.75%200%2001.02-1.06z%22%20clip-rule%3D%22evenodd%22%2F%3E%3C%2Fsvg%3E')]" %>
    </div>
    <div>
      <%= form.label :user_ids, "Authors", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div class="flex flex-wrap gap-2 p-4 border border-gray-300 rounded-lg">
        <% User.all.each do |user| %>
          <label class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-gray-300 cursor-pointer has-checked:bg-blue-50 has-checked:border-blue-500 has-checked:text-blue-700 has-checked:[&>span]:bg-blue-500 hover:bg-gray-50 transition-colors text-sm">
            <%= check_box_tag "forecast[user_ids][]", user.id, forecast.user_ids.include?(user.id), class: "sr-only" %>
            <span class="inline-block w-2 h-2 rounded-full bg-gray-300"></span>
            <%= user.email_address %>
          </label>
        <% end %>
      </div>
    </div>
    <div data-controller="image-preview">
      <%= form.label :image, "Image", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <label class="flex flex-col items-center justify-center w-full h-40 border-2 border-dashed border-gray-300 rounded-lg cursor-pointer hover:border-blue-400 hover:bg-blue-50/50 transition-colors">
        <div class="flex flex-col items-center justify-center pt-5 pb-6">
          <svg class="w-8 h-8 mb-3 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
          </svg>
          <p class="mb-1 text-sm text-gray-500"><span class="font-semibold text-blue-600">Click to upload</span> or drag and drop</p>
          <p class="text-xs text-gray-400">PNG, JPG, GIF, WEBP</p>
        </div>
        <%= form.file_field :image, class: "hidden", accept: "image/*", data: { image_preview_target: "input", action: "change->image-preview#show" } %>
      </label>
      <div class="mt-4 <%= 'hidden' unless forecast.image.attached? %>" data-image-preview-target="preview">
        <% if forecast.image.attached? %>
          <%= image_tag forecast.image, class: "rounded-lg border border-gray-200 w-72", data: { image_preview_target: "previewImage" } %>
        <% else %>
          <img class="rounded-lg border border-gray-200 w-72" data-image-preview-target="previewImage" />
        <% end %>
      </div>
    </div>
    <div>
      <%= form.label :short_text, "Testo breve", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.rich_text_area :short_text, class: "w-full min-h-[200px] px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
    </div>
    <div>
      <%= form.label :discussion, "Discussione", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.rich_text_area :discussion, class: "w-full min-h-[300px] px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
    </div>
    <div>
      <%= form.label :summary, "Summary", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.rich_text_area :summary, class: "w-full min-h-[300px] px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors", value: forecast.summary.body || Forecast::DEFAULT_SUMMARY %>
    </div>
    <div class="flex items-center justify-between pt-4 border-t border-gray-200">
      <%= link_to "Cancel", admin_forecasts_path, class: "px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors font-medium" %>
      <%= form.submit forecast.new_record? ? "Create Forecast" : "Update Forecast",
          class: "admin-btn-primary" %>
    </div>
  <% end %>
</div>
