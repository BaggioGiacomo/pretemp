<div class="admin-page py-6">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render "admin/shared/form_page_header",
        title: "Edit Forecast",
        description: "Update forecast details",
        back_path: admin_forecasts_path %>
    <%= render "form", forecast: @forecast %>
    <div class="mt-6">
      <%= button_to "Delete Forecast", 
          admin_forecast_path(@forecast), 
          method: :delete, 
          data: { turbo_confirm: "Are you sure you want to delete this forecast?" },
          class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors font-medium" %>
    </div>
  </div>
</div>