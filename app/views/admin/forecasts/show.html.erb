<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-6">
      <div class="flex items-center justify-between">
        <%= link_to admin_forecasts_path, class: "text-gray-600 hover:text-gray-900 transition-colors" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
        <% end %>
        <div class="flex items-center space-x-3">
          <%= link_to "Edit", edit_admin_forecast_path(@forecast), class: "px-4 py-2 text-blue-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-colors font-medium" %>
          <%= button_to "Delete", 
              admin_forecast_path(@forecast), 
              method: :delete, 
              data: { turbo_confirm: "Are you sure you want to delete this forecast?" },
              class: "px-4 py-2 text-red-600 hover:text-red-700 hover:bg-red-50 rounded-lg transition-colors font-medium" %>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="p-8">
        <div class="mb-6">
          <h1 class="text-3xl font-bold text-gray-900"><%= @forecast.title %></h1>
          <div class="mt-4 flex items-center space-x-4 text-sm text-gray-500">
            <span class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <%= @forecast.forecast_date.strftime("%B %d, %Y") if @forecast.forecast_date %>
            </span>
            <span class="px-3 py-1 rounded-full text-xs font-medium <%= @forecast.status == 'published' ? 'bg-green-100 text-green-800' : @forecast.status == 'draft' ? 'bg-yellow-100 text-yellow-800' : 'bg-gray-100 text-gray-800' %>">
              <%= @forecast.status&.capitalize %>
            </span>
          </div>
        </div>

        <div class="prose max-w-none">
          <%= @forecast.content %>
        </div>
      </div>

      <div class="bg-gray-50 px-8 py-4 border-t border-gray-200">
        <div class="text-sm text-gray-500">
          <p>Created: <%= @forecast.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
          <p>Last updated: <%= @forecast.updated_at.strftime("%B %d, %Y at %I:%M %p") %></p>
        </div>
      </div>
    </div>
  </div>
</div>