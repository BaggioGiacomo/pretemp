<div class="admin-surface rounded-2xl p-8">
  <div class="flex justify-center">
    <div class="w-72 bg-linear-to-br  rounded-xl flex items-center justify-center">
      <%= image_tag "logo.svg", alt: "Logo", class: "h-10 w-auto" %>
    </div>
  </div>
  <h1 class="text-2xl font-bold text-slate-900 mb-2 text-center">Complete your registration</h1>
  <p class="text-slate-600 text-sm text-center mb-8">Create a password for your <strong><%= @invitation.email %></strong></p>
  <%= form_with url: accept_admin_invitation_path(token: @invitation.token), method: :post, class: "space-y-5" do |f| %>
    <div>
      <%= f.label :first_name, "First Name", class: "block text-sm font-medium text-slate-700 mb-2" %>
      <%= f.text_field :first_name, required: true, autofocus: true, autocomplete: "given-name",
          placeholder: "First name",
          class: "block w-full rounded-xl bg-white/90 border border-slate-300 text-slate-900 placeholder-slate-400 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition-all duration-200" %>
    </div>
    <div>
      <%= f.label :last_name, "Last Name", class: "block text-sm font-medium text-slate-700 mb-2" %>
      <%= f.text_field :last_name, required: true, autocomplete: "family-name",
          placeholder: "Last name",
          class: "block w-full rounded-xl bg-white/90 border border-slate-300 text-slate-900 placeholder-slate-400 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition-all duration-200" %>
    </div>
    <div>
      <%= f.label :password, "Password", class: "block text-sm font-medium text-slate-700 mb-2" %>
      <%= f.password_field :password, required: true, autocomplete: "new-password",
          placeholder: "••••••••",
          class: "block w-full rounded-xl bg-white/90 border border-slate-300 text-slate-900 placeholder-slate-400 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition-all duration-200" %>
    </div>
    <div>
      <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-slate-700 mb-2" %>
      <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
          placeholder: "••••••••",
          class: "block w-full rounded-xl bg-white/90 border border-slate-300 text-slate-900 placeholder-slate-400 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition-all duration-200" %>
    </div>
    <div class="pt-2">
      <%= f.submit "Create Account", class: "admin-btn-primary w-full cursor-pointer" %>
    </div>
  <% end %>
</div>
