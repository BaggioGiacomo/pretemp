<div class="admin-page py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900">Admin Management</h1>
        <p class="mt-1 text-sm text-slate-600">Manage active admins and invitation flow from one place.</p>
      </div>
      <%= link_to "Invite Admin", new_admin_invitation_path, class: "admin-btn-primary text-center" %>
    </div>
    <div class="admin-surface overflow-hidden mb-8">
      <div class="px-6 py-4 border-b border-slate-200/80">
        <h2 class="text-lg font-medium text-gray-900">Active Admins</h2>
      </div>
      <!-- Desktop table -->
      <table class="hidden sm:table min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Created</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200/80">
          <% User.order(:created_at).each do |admin| %>
            <tr class="hover:bg-white/60 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= admin.email_address %>
                <% if admin == current_user %>
                  <span class="ml-2 px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-800">You</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                <%= admin.created_at.strftime("%b %d, %Y") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <% if admin != current_user %>
                  <%= button_to "Reset Password", 
                      generate_password_reset_admin_user_path(admin), 
                      method: :post,
                      class: "text-blue-600 hover:text-blue-800 cursor-pointer" %>
                <% else %>
                  <span class="text-gray-400">—</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <!-- Mobile cards -->
      <div class="sm:hidden divide-y divide-gray-200">
        <% User.order(:created_at).each do |admin| %>
          <div class="p-4 space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-sm font-medium text-gray-900 truncate">
                <%= admin.email_address %>
                <% if admin == current_user %>
                  <span class="ml-1 px-2 py-0.5 text-xs font-medium rounded-full bg-blue-100 text-blue-800">You</span>
                <% end %>
              </span>
            </div>
            <div class="flex items-center justify-between text-sm">
              <span class="text-gray-500"><%= admin.created_at.strftime("%b %d, %Y") %></span>
              <% if admin != current_user %>
                <%= button_to "Reset Password", 
                    generate_password_reset_admin_user_path(admin), 
                    method: :post,
                    class: "text-blue-600 hover:text-blue-800 cursor-pointer text-sm" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    <div class="admin-surface overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-200/80">
        <h2 class="text-lg font-medium text-gray-900">Pending Invitations</h2>
      </div>
      <!-- Desktop table -->
      <table class="hidden sm:table min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Invited By</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expires</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200/80">
          <% if @invitations.not_accepted.any? %>
            <% @invitations.not_accepted.each do |invitation| %>
              <tr class="hover:bg-white/60 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= invitation.email %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <% if invitation.accepted? %>
                    <span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800">Accepted</span>
                  <% elsif invitation.expired? %>
                    <span class="px-2 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-800">Expired</span>
                  <% else %>
                    <span class="px-2 py-1 text-xs font-medium rounded-full bg-yellow-100 text-yellow-800">Pending</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                  <%= invitation.invited_by&.email_address || "—" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                  <%= invitation.expires_at.strftime("%b %d, %Y %H:%M") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                  <% if invitation.acceptable? %>
                    <%= button_to "Cancel", admin_invitation_path(invitation), method: :delete, 
                        class: "text-red-600 hover:text-red-800",
                        data: { turbo_confirm: "Are you sure?" } %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5" class="px-6 py-4 text-center text-sm text-gray-500">
                No pending invitations
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <!-- Mobile cards -->
      <div class="sm:hidden divide-y divide-gray-200">
        <% if @invitations.not_accepted.any? %>
          <% @invitations.not_accepted.each do |invitation| %>
            <div class="p-4 space-y-2">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-gray-900 truncate"><%= invitation.email %></span>
                <% if invitation.accepted? %>
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-green-100 text-green-800">Accepted</span>
                <% elsif invitation.expired? %>
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 text-gray-800">Expired</span>
                <% else %>
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-yellow-100 text-yellow-800">Pending</span>
                <% end %>
              </div>
              <div class="flex items-center justify-between text-xs text-gray-500">
                <span>By: <%= invitation.invited_by&.email_address || "—" %></span>
                <span>Exp: <%= invitation.expires_at.strftime("%b %d, %Y") %></span>
              </div>
              <% if invitation.acceptable? %>
                <div class="pt-1">
                  <%= button_to "Cancel", admin_invitation_path(invitation), method: :delete,
                      class: "text-red-600 hover:text-red-800 text-sm",
                      data: { turbo_confirm: "Are you sure?" } %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="p-4 text-center text-sm text-gray-500">No pending invitations</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
