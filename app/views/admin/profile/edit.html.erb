<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Edit Profile</h1>
      <p class="mt-2 text-gray-600 text-sm">Update your personal information and profile picture.</p>
    </div>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <%= form_with(model: @user, url: admin_profile_path, method: :patch, local: true, class: "space-y-6") do |form| %>
        <% if @user.errors.any? %>
          <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg" role="alert">
            <div class="font-semibold mb-2"><%= pluralize(@user.errors.count, "error") %> prohibited this profile from being saved:</div>
            <ul class="list-disc list-inside space-y-1">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        <div>
          <%= form.label :first_name, "First Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :first_name, required: true, autocomplete: "given-name",
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
        </div>
        <div>
          <%= form.label :last_name, "Last Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :last_name, required: true, autocomplete: "family-name",
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
        </div>
        <div data-controller="image-preview">
          <%= form.label :profile_image, "Profile Picture", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <label class="flex flex-col items-center justify-center w-full h-40 border-2 border-dashed border-gray-300 rounded-lg cursor-pointer hover:border-blue-400 hover:bg-blue-50/50 transition-colors">
            <div class="flex flex-col items-center justify-center pt-5 pb-6">
              <svg class="w-8 h-8 mb-3 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
              </svg>
              <p class="mb-1 text-sm text-gray-500"><span class="font-semibold text-blue-600">Click to upload</span> or drag and drop</p>
              <p class="text-xs text-gray-400">PNG, JPG, GIF, WEBP</p>
            </div>
            <%= form.file_field :profile_image, class: "hidden", accept: "image/*", data: { image_preview_target: "input", action: "change->image-preview#show" } %>
          </label>
          <div class="mt-4 <%= 'hidden' unless @user.profile_image.attached? %>" data-image-preview-target="preview">
            <% if @user.profile_image.attached? %>
              <%= image_tag @user.profile_image, class: "rounded-full border border-gray-200 w-24 h-24 object-cover", data: { image_preview_target: "previewImage" } %>
            <% else %>
              <img class="rounded-full border border-gray-200 w-24 h-24 object-cover" data-image-preview-target="previewImage" />
            <% end %>
          </div>
        </div>
        <div data-controller="file-preview">
          <%= form.label :curriculum, "Curriculum Vitae", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-gray-300 rounded-lg cursor-pointer hover:border-blue-400 hover:bg-blue-50/50 transition-colors">
            <div class="flex flex-col items-center justify-center pt-4 pb-4">
              <svg class="w-8 h-8 mb-2 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
              <p class="mb-1 text-sm text-gray-500"><span class="font-semibold text-blue-600">Click to upload</span> your CV</p>
              <p class="text-xs text-gray-400">PDF, DOC, DOCX</p>
            </div>
            <%= form.file_field :curriculum, class: "hidden", accept: ".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document", data: { file_preview_target: "input", action: "change->file-preview#show" } %>
          </label>
          <div class="mt-3 hidden flex items-center gap-2 text-sm text-blue-600" data-file-preview-target="preview">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <span data-file-preview-target="fileName"></span>
          </div>
          <% if @user.curriculum.attached? %>
            <div class="mt-3 flex items-center justify-between">
              <div class="flex items-center gap-2 text-sm text-gray-600">
                <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <%# Replace the simple name with a link  %>
                <span>Current file: <%= link_to @user.curriculum.filename, rails_blob_path(@user.curriculum, disposition: "inline"), target: "_blank", rel: "noopener noreferrer", class: "text-sky-400 text-underline" %></span>
              </div>
              <%= link_to "Remove",
                remove_curriculum_admin_profile_path,
                data: {
                  turbo_method: :delete,
                  turbo_confirm: "Are you sure you want to remove the curriculum?"
                },
                class: "text-sm text-red-600 hover:text-red-800 font-medium cursor-pointer" 
              %>
            </div>
          <% end %>
        </div>
        <div>
          <%= form.label :description, "Description", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.rich_text_area :description, class: "w-full min-h-[200px] px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
        </div>
        <div class="flex items-center justify-between pt-4 border-t border-gray-200">
          <%= link_to "Cancel", admin_root_path, class: "px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors font-medium" %>
          <%= form.submit "Update Profile", class: "px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors font-medium cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
