<div class="admin-page py-6">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render "admin/shared/form_page_header",
        title: "Edit Satellite Monitoring",
        description: "Update monitoring details",
        back_path: admin_satellite_monitorings_path %>
    <%= render "admin/shared/monitoring_form", monitoring: @monitoring, index_path: admin_satellite_monitorings_path %>
    <div class="mt-6">
      <%= button_to "Delete",
          admin_satellite_monitoring_path(@monitoring),
          method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete this?" },
          class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors font-medium cursor-pointer" %>
    </div>
  </div>
</div>
