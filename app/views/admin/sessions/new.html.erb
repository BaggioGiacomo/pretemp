<div class="admin-surface rounded-2xl p-8">
  <div class="flex justify-center">
    <div class="w-72 bg-linear-to-br  rounded-xl flex items-center justify-center">
      <%= image_tag "logo.svg", alt: "Logo", class: "h-10 w-auto" %>
    </div>
  </div>
  <h1 class="text-2xl font-bold text-slate-900 mb-2 text-center">Welcome back</h1>
  <p class="text-slate-600 text-sm text-center mb-8">Sign in to your admin account</p>
  <%= form_with url: admin_login_path, class: "space-y-5" do |f| %>
    <div>
      <%= f.label :email, "Email", class: "block text-sm font-medium text-slate-700 mb-2" %>
      <%= f.email_field :email, required: true, autofocus: true, autocomplete: "email",
          placeholder: "admin@example.com",
          class: "block w-full rounded-xl bg-white/90 border border-slate-300 text-slate-900 placeholder-slate-400 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition-all duration-200" %>
    </div>
    <div>
      <%= f.label :password, "Password", class: "block text-sm font-medium text-slate-700 mb-2" %>
      <%= f.password_field :password, required: true, autocomplete: "current-password",
          placeholder: "••••••••",
          class: "block w-full rounded-xl bg-white/90 border border-slate-300 text-slate-900 placeholder-slate-400 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition-all duration-200" %>
    </div>
    <div class="pt-2">
      <%= f.submit "Sign in", class: "admin-btn-primary w-full cursor-pointer" %>
    </div>
  <% end %>
</div>
<p class="text-center text-slate-500 text-xs mt-8">Protected admin area</p>
