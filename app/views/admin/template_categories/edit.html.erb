<div class="admin-page py-6">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render "admin/shared/form_page_header",
        title: "Edit Category",
        description: "Update category details",
        back_path: admin_template_categories_path %>
    <%= render "form", template_category: @template_category %>
    <div class="mt-6">
      <%= button_to "Delete Category",
          admin_template_category_path(@template_category),
          method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete this category and all its templates?" },
          class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors font-medium" %>
    </div>
  </div>
</div>
