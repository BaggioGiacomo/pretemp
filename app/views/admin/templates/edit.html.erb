<div class="admin-page py-6">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render "admin/shared/form_page_header",
        title: "Edit Template",
        description: "Update template in #{@template_category.name}",
        back_path: admin_template_category_templates_path(@template_category) %>
    <%= render "form", template: @template %>
    <div class="mt-6">
      <%= button_to "Delete Template",
          admin_template_category_template_path(@template_category, @template),
          method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete this template?" },
          class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors font-medium" %>
    </div>
  </div>
</div>
