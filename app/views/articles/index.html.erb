<section class="max-w-6xl mx-auto px-4 py-10 md:py-16">
  <div class="mb-8 md:mb-12">
    <h1 class="text-2xl md:text-3xl font-semibold tracking-tight">Blog</h1>
    <p class="mt-2 text-sm text-slate-400">
      Articoli e approfondimenti dal team PRETEMP.
    </p>
  </div>
  <% if @articles.any? %>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <% @articles.each do |article| %>
        <%= link_to article_path(article),
            class: "group rounded-2xl border border-slate-800 bg-slate-900/80 p-5 flex flex-col justify-between hover:border-sky-500/60 hover:bg-slate-900 transition" do %>
          <div class="space-y-2">
            <p class="text-[11px] text-slate-500">
              <%= l(article.created_at, format: :long) %>
            </p>
            <h2 class="text-lg font-semibold text-slate-100 group-hover:text-white line-clamp-2">
              <%= article.title %>
            </h2>
            <p class="text-xs text-slate-400 line-clamp-3">
              <%= article.body.to_plain_text.truncate(180) %>
            </p>
          </div>
          <div class="mt-4 flex items-center justify-between">
            <span class="text-xs font-medium text-sky-300 group-hover:text-sky-200">Leggi di più</span>
            <svg class="w-4 h-4 text-sky-400 group-hover:text-sky-300 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-slate-800 bg-slate-900/80 p-12 text-center">
      <p class="text-sm text-slate-400">Nessun articolo pubblicato.</p>
    </div>
  <% end %>
</section>
