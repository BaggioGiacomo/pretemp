<section class="max-w-4xl mx-auto px-4 py-10 md:py-16 forecast-ambient forecast-ambient--<%= @forecast.risk_level %>">
  <nav class="mb-8 relative z-10">
    <ol class="flex items-center gap-2 text-xs text-slate-500">
      <li>
        <%= link_to "Home", root_path, class: "hover:text-slate-200 transition-colors" %>
      </li>
      <li>
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
        </svg>
      </li>
      <li>
        <%= link_to "Archivio", archivio_index_path, class: "hover:text-slate-200 transition-colors" %>
      </li>
      <li>
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
        </svg>
      </li>
      <li class="text-slate-300 font-medium truncate"><%= @forecast.title %></li>
    </ol>
  </nav>
  <article class="relative z-10 rounded-2xl bg-slate-900/80 overflow-hidden forecast-card-border">
    <div class="px-6 md:px-10 py-8 md:py-10 space-y-5">
      <div class="flex flex-col-reverse sm:flex-row justify-between gap-4">
        <h1 class="text-2xl md:text-3xl font-semibold tracking-tight text-slate-50 section-heading-accent">
          <%= @forecast.title %>
        </h1>
        <span class="flex items-center rounded-full border px-3 py-1 text-xs font-medium w-fit risk-badge-glow risk-badge-glow--<%= @forecast.risk_level %>
          <%= case @forecast.risk_level
            when "basso"
              "border-yellow-500/40 bg-yellow-500/10 text-yellow-200"
            when "medio"
              "border-orange-500/40 bg-orange-500/10 text-orange-200"
            when "alto"
              "border-red-500/40 bg-red-500/10 text-red-200"
            when "molto_alto"
              "border-purple-500/40 bg-purple-500/10 text-purple-200"
            else
              "border-emerald-500/40 bg-emerald-500/10 text-emerald-200"
            end %>">
          <% if @forecast.risk_level.nil? %>
            Nessun pericolo
          <% else %>
            Pericolosità <%= @forecast.risk_level_before_type_cast %>
          <% end %>
        </span>
      </div>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-slate-500">
        <p>
          <%= "previsore".pluralize(@forecast.users&.count, :it).capitalize %>:
          <span class="font-medium text-slate-300"><%= @forecast.authors %></span>
        </p>
        <span class="hidden sm:inline text-slate-700">&middot;</span>
        <p>Aggiornato il <%= I18n.l(@forecast.updated_at, format: :long) %></p>
      </div>
    </div>
    <% if @active_update %>
      <div class="forecast-section-divider" style="--divider-color: rgba(245,158,11,0.25);"></div>
      <div class="px-6 md:px-10 py-6 bg-amber-500/5 border-l-4 border-amber-500/40">
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-flex items-center rounded-full border border-amber-500/40 bg-amber-500/10 px-2.5 py-0.5 text-xs font-semibold text-amber-200">
            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Aggiornamento
          </span>
          <span class="text-[10px] text-slate-500">
            Valido fino alle <%= I18n.l(@active_update.valid_until, format: :short) %>
          </span>
        </div>
        <div class="prose prose-invert prose-base max-w-prose mx-auto text-slate-300 leading-relaxed prose-headings:text-slate-100 prose-a:text-sky-300 prose-strong:text-slate-100 prose-p:my-3">
          <%= @active_update.body %>
        </div>
        <% if @active_update.image.attached? %>
          <div class="flex items-center justify-center bg-slate-950/30 p-4 mt-4 rounded-lg">
            <%= image_tag @active_update.image,
                  class: "w-full h-auto max-w-[600px] rounded-lg shadow-lg shadow-slate-950/50",
                  alt: "Aggiornamento previsione" %>
          </div>
        <% end %>
        <div class="flex items-center justify-between mt-3 text-[11px] text-slate-500">
          <p><%= @active_update.authors %></p>
          <p><%= time_ago_in_words(@active_update.created_at) %> fa</p>
        </div>
      </div>
    <% end %>
    <% if @forecast.image.attached? %>
      <div class="forecast-section-divider" style="--divider-color: <%= case @forecast.risk_level
        when 'basso' then 'rgba(234,179,8,0.25)'
        when 'medio' then 'rgba(249,115,22,0.25)'
        when 'alto' then 'rgba(239,68,68,0.25)'
        when 'molto_alto' then 'rgba(168,85,247,0.25)'
        else 'rgba(16,185,129,0.25)'
      end %>;"></div>
      <div class="flex items-center justify-center bg-slate-950/50 p-6 md:p-10">
        <%= image_tag @forecast.image,
              class: "w-full h-auto max-w-[800px] rounded-lg forecast-image-reveal shadow-lg shadow-slate-950/50",
              alt: "Mappa #{@forecast.label.downcase} del #{I18n.l(@forecast.date, format: :long) if @forecast.date}" %>
      </div>
    <% end %>
    <div class="forecast-section-divider" style="--divider-color: <%= case @forecast.risk_level
      when 'basso' then 'rgba(234,179,8,0.25)'
      when 'medio' then 'rgba(249,115,22,0.25)'
      when 'alto' then 'rgba(239,68,68,0.25)'
      when 'molto_alto' then 'rgba(168,85,247,0.25)'
      # Use an emerald color similar to the one used for the "Nessun pericolo" badge
      else 'rgba(16,185,129,0.25)'
      end %>;"></div>
    <div class="px-6 md:px-10 py-10 md:py-14">
      <div class="prose prose-invert prose-lg max-w-prose mx-auto
                  text-slate-300 leading-relaxed
                  prose-headings:text-slate-100
                  prose-a:text-sky-300 hover:prose-a:text-sky-200
                  prose-strong:text-slate-100
                  prose-p:my-5">
        <%= @forecast.body %>
      </div>
    </div>
    <% if @forecast.summary.present? %>
      <div class="forecast-section-divider" style="--divider-color: <%= case @forecast.risk_level
        when 'basso' then 'rgba(234,179,8,0.25)'
        when 'medio' then 'rgba(249,115,22,0.25)'
        when 'alto' then 'rgba(239,68,68,0.25)'
        when 'molto_alto' then 'rgba(168,85,247,0.25)'
        else 'rgba(16,185,129,0.25)'
      end %>;"></div>
      <div class="p-6 md:px-10 bg-slate-950/50">
        <div class="forecast-summary-box pl-5 py-2 prose prose-invert prose-lg mx-auto
                  text-slate-300 leading-relaxed
                  prose-headings:text-slate-100
                  prose-a:text-sky-300 hover:prose-a:text-sky-200
                  prose-strong:text-slate-100
                  prose-p:my-5">
          <%= @forecast.summary %>
        </div>
      </div>
    <% end %>
    <div class="forecast-section-divider" style="--divider-color: <%= case @forecast.risk_level
      when 'basso' then 'rgba(234,179,8,0.25)'
      when 'medio' then 'rgba(249,115,22,0.25)'
      when 'alto' then 'rgba(239,68,68,0.25)'
      when 'molto_alto' then 'rgba(168,85,247,0.25)'
      else 'rgba(16,185,129,0.25)'
    end %>;"></div>
    <div class="px-6 md:px-10 py-5 bg-slate-950/50">
      <div class="flex items-center justify-between">
        <%= link_to archivio_index_path,
              class: "inline-flex items-center text-xs font-medium text-sky-300 hover:text-sky-200 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Torna all'archivio
        <% end %>
        <%= link_to come_leggere_la_previsione_path,
              class: "inline-flex items-center text-xs font-medium text-indigo-300 hover:text-indigo-200 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
          Come leggere la previsione
        <% end %>
        <%= link_to significato_delle_sigle_path,
              class: "inline-flex items-center text-xs font-medium text-emerald-300 hover:text-emerald-200 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
          </svg>
          Significato delle sigle
        <% end %>
        <p class="text-[11px] text-slate-500">
          <%= I18n.l(@forecast.date, format: :long) if @forecast.date %>
        </p>
      </div>
    </div>
  </article>
</section>
