<% variant = local_assigns.fetch(:variant, nil) %>
<% has_update = forecast.active_update.present? %>
<%= link_to forecast_path(forecast), class: "card-storm-glow rounded-2xl border #{has_update ? 'border-amber-500/30' : 'border-slate-800'} bg-slate-900/80 shadow-2xl shadow-slate-950/60 p-4 md:p-5 flex flex-col gap-2 h-full hover:border-sky-500/60 hover:bg-slate-900 transition" do %>
  <div class="flex items-center justify-between gap-4">
    <p class="text-xs uppercase tracking-wide text-slate-500">
      <% if variant == :latest %>
        Ultima <%= forecast.label.downcase %>
      <% else %>
        <%= forecast.label %>
      <% end %>
    </p>
    <span class="inline-flex items-center rounded-full border px-3 py-1 text-xs text-nowrap font-semibold <%= case forecast.risk_level
            when "basso"
              "border-yellow-500/40 bg-yellow-500/10 text-yellow-200"
            when "medio"
              "border-orange-500/40 bg-orange-500/10 text-orange-200"
            when "alto"
              "border-red-500/40 bg-red-500/10 text-red-200"
            when "molto_alto"
              "border-purple-500/40 bg-purple-500/10 text-purple-200"
            else
              "bg-gray-100 text-gray-800 border-gray-300"
            end %>">
      Pericolosità <%= forecast.risk_level_before_type_cast %>
    </span>
  </div>
  <% if has_update %>
    <div class="flex items-center gap-1.5 rounded-lg border border-amber-500/20 bg-amber-500/5 px-2.5 py-1.5">
      <svg class="w-3.5 h-3.5 text-amber-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-[11px] text-amber-300 font-medium">Aggiornamento disponibile</p>
    </div>
  <% end %>
  <p class="text-sm font-semibold text-slate-100">
    <%= I18n.l(forecast.date, format: :long) if forecast.date %>
  </p>
  <p class="text-xs text-slate-300">
    <%= "autore".pluralize(forecast.users&.count, :it).capitalize %>:
    <span class="font-medium text-slate-100">
      <%= forecast.authors %>
    </span>
  </p>
  <div class="flex items-center justify-center bg-slate-950/50 p-2 rounded-lg max-w-[300px] overflow-hidden">
    <% if forecast.image.attached? %>
      <%= image_tag forecast.image,
            class: "w-full h-auto rounded-md",
            alt: "Mappa #{forecast.label.downcase} del #{I18n.l(forecast.date, format: :long) if forecast.date}" %>
    <% end %>
  </div>
  <div class="flex justify-end pt-2 flex-1 items-end">
    <p class="text-[11px] text-slate-500">
      Aggiornata il <%= forecast.updated_at.strftime("%d/%m/%Y %H:%M") %>
    </p>
  </div>
<% end %>
