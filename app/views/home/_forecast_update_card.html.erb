<div class="rounded-2xl border border-amber-500/30 bg-amber-500/5 shadow-2xl shadow-amber-950/20 p-4 md:p-5 flex flex-col gap-2">
  <div class="flex items-center gap-2">
    <span class="inline-flex items-center rounded-full border border-amber-500/40 bg-amber-500/10 px-2.5 py-0.5 text-xs font-semibold text-amber-200">
      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Aggiornamento attivo
    </span>
    <span class="text-[10px] text-slate-500">
      Valido fino alle <%= I18n.l(forecast_update.valid_until, format: :short) %>
    </span>
  </div>
  <div class="prose prose-invert prose-sm max-w-none text-slate-300 prose-p:my-1">
    <%= forecast_update.body %>
  </div>
  <% if forecast_update.image.attached? %>
    <div class="flex items-center justify-center bg-slate-950/50 p-2 rounded-lg max-w-[300px] overflow-hidden">
      <%= image_tag forecast_update.image,
            class: "w-full h-auto rounded-md",
            alt: "Aggiornamento previsione" %>
    </div>
  <% end %>
  <div class="flex items-center justify-between pt-1">
    <p class="text-[11px] text-slate-400">
      <%= forecast_update.authors %>
    </p>
    <p class="text-[11px] text-slate-500">
      <%= time_ago_in_words(forecast_update.created_at) %> fa
    </p>
  </div>
</div>
