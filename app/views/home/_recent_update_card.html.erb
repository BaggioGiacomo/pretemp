<%= link_to forecast_path(forecast_update.forecast), class: "card-storm-glow rounded-2xl border border-amber-500/30 bg-slate-900/80 shadow-2xl shadow-slate-950/60 p-4 md:p-5 flex flex-col gap-2 h-full hover:border-amber-500/50 hover:bg-slate-900 transition" do %>
  <div class="flex items-center justify-between gap-4">
    <p class="text-xs uppercase tracking-wide text-amber-400">
      Aggiornamento
    </p>
    <span class="inline-flex items-center rounded-full border border-amber-500/40 bg-amber-500/10 px-2.5 py-0.5 text-xs font-semibold text-amber-200">
      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Attivo
    </span>
  </div>
  <p class="text-sm font-semibold text-slate-100">
    <%= I18n.l(forecast_update.forecast.date, format: :long) if forecast_update.forecast.date %>
  </p>
  <p class="text-xs text-slate-300">
    <%= "autore".pluralize(forecast_update.users&.count, :it).capitalize %>:
    <span class="font-medium text-slate-100">
      <%= forecast_update.authors %>
    </span>
  </p>
  <% if forecast_update.image.attached? %>
    <div class="flex items-center justify-center bg-slate-950/50 p-2 rounded-lg max-w-[300px] overflow-hidden">
      <%= image_tag forecast_update.image,
            class: "w-full h-auto rounded-md",
            alt: "Aggiornamento previsione" %>
    </div>
  <% end %>
  <div class="flex items-center justify-between pt-2 flex-1 items-end">
    <p class="text-[11px] text-amber-400/70">
      Valido fino alle <%= I18n.l(forecast_update.valid_until, format: :short) %>
    </p>
    <p class="text-[11px] text-slate-500">
      <%= time_ago_in_words(forecast_update.created_at) %> fa
    </p>
  </div>
<% end %>
