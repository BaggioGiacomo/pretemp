<section class="relative overflow-hidden border-b border-slate-800 bg-linear-to-b from-slate-950 via-slate-950 to-slate-900">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(56,189,248,.18),transparent_55%),radial-gradient(circle_at_bottom,rgba(250,204,21,.12),transparent_55%)]"></div>
  <div class="relative max-w-6xl mx-auto px-4 py-6 md:py-16 grid gap-10 md:grid-cols-2 items-center">
    <div class="space-y-6">
      <p class="inline-flex items-center rounded-full border border-sky-500/40 bg-slate-950/70 px-3 py-1 text-xs font-medium text-sky-200 shadow-sm shadow-sky-500/20">
        Previsioni sperimentali probabilistiche dal 2015
      </p>
      <div class="space-y-3">
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">
          Previsioni dedicate ai temporali intensi
        </h1>
        <p class="text-sm md:text-base text-slate-300 max-w-xl">
          PRETEMP fornisce previsioni probabilistiche del rischio di fenomeni temporaleschi intensi
          su scala nazionale, con particolare attenzione alle situazioni potenzialmente pericolose.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <%= link_to "Ultima previsione", forecast_path(@latest_forecast),
            class: "inline-flex items-center justify-center rounded-xl bg-sky-500 px-4 py-2 text-sm font-medium text-slate-950 shadow-lg shadow-sky-500/30 hover:bg-sky-400 transition" %>
        <%= link_to "Come funziona la previsione", guida_alle_previsioni_path,
            class: "inline-flex items-center justify-center rounded-xl border border-slate-700 px-4 py-2 text-sm font-medium text-slate-100 hover:bg-slate-900 transition" %>
      </div>
    </div>
    <div class="md:pl-8">
      <%= render "forecast_card", forecast: @latest_forecast %>
    </div>
  </div>
</section>
<section class="max-w-6xl mx-auto px-4 py-10 md:py-12 border-b border-slate-800">
  <div class="flex items-center justify-between gap-4 mb-4">
    <h2 class="text-lg md:text-xl font-semibold tracking-tight">Previsioni recenti</h2>
    <%= link_to "Vai all'archivio", archivio_index_path,
        class: "text-xs font-medium text-slate-400 hover:text-slate-200" %>
  </div>
  <div class="grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
    <% (@latest_forecasts || []).each do |forecast| %>
      <%= render "forecast_card", forecast: forecast %>
    <% end %>
    <% if (@latest_forecasts || []).empty? %>
      <p class="text-xs text-slate-400">
        Le previsioni verranno mostrate qui non appena disponibili.
      </p>
    <% end %>
  </div>
</section>
<section class="max-w-6xl mx-auto px-4 py-10 md:py-12 border-b border-slate-800">
  <div class="flex items-center justify-between gap-4 mb-4">
    <h2 class="text-lg md:text-xl font-semibold tracking-tight">Articoli recenti</h2>
    <%= link_to "Vai al blog", articles_path,
        class: "text-xs font-medium text-slate-400 hover:text-slate-200" %>
  </div>
  <div class="grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
    <% if @latest_articles.present? %>
      <% @latest_articles.each do |article| %>
        <%= render "article_card", article: article %>
      <% end %>
    <% else %>
      <p class="text-xs text-slate-400">
        Gli articoli verranno mostrati qui non appena disponibili.
      </p>
    <% end %>
  </div>
</section>
<section class="max-w-6xl mx-auto px-4 py-4 md:py-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <h2 class="text-lg md:text-xl font-semibold tracking-tight">Area operativa</h2>
  </div>
  <div class="grid gap-4 md:grid-cols-4">
    <%= link_to monitoraggio_radar_path,
        class: "group rounded-2xl border border-slate-800 bg-slate-900/80 p-4 flex flex-col justify-between hover:border-sky-500/60 hover:bg-slate-900 transition" do %>
      <div>
        <p class="text-xs font-semibold text-slate-200 mb-1">Radar</p>
        <p class="text-[11px] text-slate-400">
          Riflettività radar in tempo quasi reale per seguire l'evoluzione delle celle temporalesche.
        </p>
      </div>
      <span class="mt-3 text-[11px] font-medium text-sky-300 group-hover:text-sky-200">
        Apri radar →
      </span>
    <% end %>
    <%= link_to monitoraggio_radiosondaggi_path,
        class: "group rounded-2xl border border-slate-800 bg-slate-900/80 p-4 flex flex-col justify-between hover:border-sky-500/60 hover:bg-slate-900 transition" do %>
      <div>
        <p class="text-xs font-semibold text-slate-200 mb-1">Radiosondaggi</p>
        <p class="text-[11px] text-slate-400">
          Profili verticali per valutare l'instabilità e il potenziale convettivo.
        </p>
      </div>
      <span class="mt-3 text-[11px] font-medium text-sky-300 group-hover:text-sky-200">
        Consulta pseudosondaggi →
      </span>
    <% end %>
    <%= link_to templates_path,
        class: "group rounded-2xl border border-slate-800 bg-slate-900/80 p-4 flex flex-col justify-between hover:border-sky-500/60 hover:bg-slate-900 transition" do %>
      <div>
        <p class="text-xs font-semibold text-slate-200 mb-1">Modelli WRF</p>
        <p class="text-[11px] text-slate-400">
          Campi previsionali ad alta risoluzione da diverse catene modellistiche.
        </p>
      </div>
      <span class="mt-3 text-[11px] font-medium text-sky-300 group-hover:text-sky-200">
        Vai ai modelli →
      </span>
    <% end %>
    <%= link_to "#",
        class: "group rounded-2xl border border-slate-800 bg-slate-900/80 p-4 flex flex-col justify-between hover:border-amber-400/60 hover:bg-slate-900 transition" do %>
      <div>
        <p class="text-xs font-semibold text-slate-200 mb-1">Segnalazioni</p>
        <p class="text-[11px] text-slate-400">
          Accedi al progetto Storm Report Italia e alle segnalazioni di fenomeni violenti.
        </p>
      </div>
      <span class="mt-3 text-[11px] font-medium text-amber-200 group-hover:text-amber-100">
        Storm Report →
      </span>
    <% end %>
  </div>
</section>
