<!DOCTYPE html>
<html>
  <head>
    <title>Pretemp - Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= favicon_link_tag "favicon.png", type: "image/png" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="admin-ui min-h-screen">
    <div class="admin-noise"></div>
    <div class="admin-glow admin-glow--one"></div>
    <div class="admin-glow admin-glow--two"></div>
    <nav class="admin-nav" data-controller="dropdown">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="hidden sm:block py-3">
          <div class="flex items-center justify-between gap-4">
            <%= link_to admin_root_path, class: "admin-brand" do %>
              <span class="admin-brand-dot"></span>
              <span class="admin-brand-title">PRETEMP Admin</span>
            <% end %>
            <div class="flex items-center gap-3">
              <%= link_to "Back to site", root_path, class: "admin-nav-link admin-nav-link-muted" %>
              <%= link_to edit_admin_profile_path, class: "flex items-center gap-2 text-sm text-slate-700 hover:text-slate-900" do %>
                <% if current_user.profile_image.attached? %>
                  <%= image_tag current_user.profile_image, class: "w-9 h-9 rounded-full object-cover border border-white/70 shadow-sm" %>
                <% else %>
                  <span class="w-9 h-9 rounded-full bg-linear-to-br from-sky-100 to-blue-200 text-blue-700 flex items-center justify-center text-xs font-semibold shadow-sm"><%= current_user.username.split(" ").map { |name| name[0] }.join %></span>
                <% end %>
                <span class="truncate max-w-[180px]"><%= current_user.username %></span>
              <% end %>
              <%= button_to "Logout", admin_logout_path, method: :delete, class: "admin-btn-danger !px-3 !py-1.5 !text-sm" %>
            </div>
          </div>
          <div class="admin-nav-track mt-3">
            <%= link_to "Dashboard", admin_root_path, class: "admin-nav-link #{current_page?(admin_root_path) ? 'admin-nav-link-active' : ''}" %>
            <%= link_to "Invitations", admin_invitations_path, class: "admin-nav-link #{current_page?(admin_invitations_path) ? 'admin-nav-link-active' : ''}" %>
            <%= link_to "Forecasts", admin_forecasts_path, class: "admin-nav-link #{current_page?(admin_forecasts_path) ? 'admin-nav-link-active' : ''}" %>
            <%= link_to "Articles", admin_articles_path, class: "admin-nav-link #{current_page?(admin_articles_path) ? 'admin-nav-link-active' : ''}" %>
            <%= link_to "Templates", admin_template_categories_path, class: "admin-nav-link #{controller_name.in?(%w[template_categories templates]) ? 'admin-nav-link-active' : ''}" %>
            <%= link_to "Didattica", admin_didattica_sections_path, class: "admin-nav-link #{controller_name.in?(%w[didattica_sections didattica_items]) ? 'admin-nav-link-active' : ''}" %>
            <div class="relative" data-controller="dropdown" data-dropdown-hover-value="true" data-action="mouseenter->dropdown#mouseEnter mouseleave->dropdown#mouseLeave">
              <button type="button" data-dropdown-target="trigger" data-action="click->dropdown#toggle" class="admin-nav-link inline-flex items-center gap-1 <%= controller_name.include?('monitoring') ? 'admin-nav-link-active' : '' %>">
                Monitoring
                <svg class="w-4 h-4 transition-transform" data-dropdown-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="admin-nav-panel hidden absolute left-0 top-full mt-2 w-52 rounded-xl py-2 z-50" data-dropdown-target="panel">
                <%= link_to "Radar", admin_radar_monitorings_path, class: "admin-nav-sub-link #{current_page?(admin_radar_monitorings_path) ? 'admin-nav-sub-link-active' : ''}" %>
                <%= link_to "Satellites", admin_satellite_monitorings_path, class: "admin-nav-sub-link #{current_page?(admin_satellite_monitorings_path) ? 'admin-nav-sub-link-active' : ''}" %>
                <%= link_to "Radio Polls", admin_radio_poll_monitorings_path, class: "admin-nav-sub-link #{current_page?(admin_radio_poll_monitorings_path) ? 'admin-nav-sub-link-active' : ''}" %>
                <%= link_to "Weather Stations", admin_weather_station_monitorings_path, class: "admin-nav-sub-link #{current_page?(admin_weather_station_monitorings_path) ? 'admin-nav-sub-link-active' : ''}" %>
                <%= link_to "Lightnings", admin_lightning_monitorings_path, class: "admin-nav-sub-link #{current_page?(admin_lightning_monitorings_path) ? 'admin-nav-sub-link-active' : ''}" %>
              </div>
            </div>
          </div>
        </div>
        <div class="flex sm:hidden items-center justify-between h-16">
          <%= link_to admin_root_path, class: "flex items-center gap-2" do %>
            <span class="admin-brand-dot"></span>
            <span class="text-slate-900 font-semibold text-sm">PRETEMP Admin</span>
          <% end %>
          <button type="button" data-action="dropdown#toggle" class="p-2 text-slate-600 hover:text-slate-900">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="hidden sm:hidden border-t border-slate-200/70" data-dropdown-target="panel">
        <div class="px-4 py-3 space-y-2">
          <%= link_to "Back to site", root_path, class: "admin-nav-mobile-link" %>
          <%= link_to "Dashboard", admin_root_path, class: "admin-nav-mobile-link #{current_page?(admin_root_path) ? 'admin-nav-mobile-link-active' : ''}" %>
          <%= link_to "Invitations", admin_invitations_path, class: "admin-nav-mobile-link #{current_page?(admin_invitations_path) ? 'admin-nav-mobile-link-active' : ''}" %>
          <%= link_to "Forecasts", admin_forecasts_path, class: "admin-nav-mobile-link #{current_page?(admin_forecasts_path) ? 'admin-nav-mobile-link-active' : ''}" %>
          <%= link_to "Articles", admin_articles_path, class: "admin-nav-mobile-link #{current_page?(admin_articles_path) ? 'admin-nav-mobile-link-active' : ''}" %>
          <%= link_to "Templates", admin_template_categories_path, class: "admin-nav-mobile-link #{controller_name.in?(%w[template_categories templates]) ? 'admin-nav-mobile-link-active' : ''}" %>
          <%= link_to "Didattica", admin_didattica_sections_path, class: "admin-nav-mobile-link #{controller_name.in?(%w[didattica_sections didattica_items]) ? 'admin-nav-mobile-link-active' : ''}" %>
          <div data-controller="dropdown">
            <button type="button" data-dropdown-target="trigger" data-action="click->dropdown#toggle" class="admin-nav-mobile-link admin-nav-mobile-trigger <%= controller_name.include?('monitoring') ? 'admin-nav-mobile-link-active' : '' %>">
              Monitoring
              <svg class="w-4 h-4 transition-transform" data-dropdown-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="hidden pl-4 space-y-1 mt-1" data-dropdown-target="panel">
              <%= link_to "Radar", admin_radar_monitorings_path, class: "admin-nav-mobile-sub-link #{current_page?(admin_radar_monitorings_path) ? 'admin-nav-mobile-sub-link-active' : ''}" %>
              <%= link_to "Satellites", admin_satellite_monitorings_path, class: "admin-nav-mobile-sub-link #{current_page?(admin_satellite_monitorings_path) ? 'admin-nav-mobile-sub-link-active' : ''}" %>
              <%= link_to "Radio Polls", admin_radio_poll_monitorings_path, class: "admin-nav-mobile-sub-link #{current_page?(admin_radio_poll_monitorings_path) ? 'admin-nav-mobile-sub-link-active' : ''}" %>
              <%= link_to "Weather Stations", admin_weather_station_monitorings_path, class: "admin-nav-mobile-sub-link #{current_page?(admin_weather_station_monitorings_path) ? 'admin-nav-mobile-sub-link-active' : ''}" %>
              <%= link_to "Lightnings", admin_lightning_monitorings_path, class: "admin-nav-mobile-sub-link #{current_page?(admin_lightning_monitorings_path) ? 'admin-nav-mobile-sub-link-active' : ''}" %>
            </div>
          </div>
        </div>
        <div class="px-4 py-3 border-t border-slate-200/70 flex justify-between items-center">
          <%= link_to edit_admin_profile_path, class: "flex items-center gap-2 text-slate-600 hover:text-slate-900 text-sm" do %>
            <% if current_user.profile_image.attached? %>
              <%= image_tag current_user.profile_image, class: "w-8 h-8 rounded-full object-cover border border-white/80" %>
            <% else %>
              <span class="w-8 h-8 rounded-full bg-linear-to-br from-sky-100 to-blue-200 text-blue-700 flex items-center justify-center text-xs font-semibold"><%= current_user.first_name&.first %><%= current_user.last_name&.first %></span>
            <% end %>
            <span class="truncate"><%= current_user.username %></span>
          <% end %>
          <%= button_to "Logout", admin_logout_path, method: :delete, class: "admin-btn-danger !px-3 !py-1.5 !text-sm" %>
        </div>
      </div>
    </nav>
    <main class="admin-main max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
      <% if flash[:notice] %>
        <div class="admin-flash admin-flash-notice mb-4 p-4 rounded-xl">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="admin-flash admin-flash-alert mb-4 p-4 rounded-xl">
          <%= flash[:alert] %>
        </div>
      <% end %>
      <%= yield %>
    </main>
    <div id="modals"></div>
  </body>
</html>
