<!DOCTYPE html>
<html>
  <head>
    <title>Pretemp - Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= favicon_link_tag "favicon.png", type: "image/png" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <nav class="bg-white shadow" data-controller="dropdown">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="hidden sm:flex items-center space-x-8">
            <%= link_to "Dashboard", admin_root_path, class: "#{current_page?(admin_root_path) ? 'text-gray-900 font-semibold' : 'text-gray-600 hover:text-gray-900'}" %>
            <%= link_to "Invitations", admin_invitations_path, class: "#{current_page?(admin_invitations_path) ? 'text-gray-900 font-semibold' : 'text-gray-600 hover:text-gray-900'}" %>
            <%= link_to "Forecasts", admin_forecasts_path, class: "#{current_page?(admin_forecasts_path) ? 'text-gray-900 font-semibold' : 'text-gray-600 hover:text-gray-900'}" %>
            <%= link_to "Articles", admin_articles_path, class: "#{current_page?(admin_articles_path) ? 'text-gray-900 font-semibold' : 'text-gray-600 hover:text-gray-900'}" %>
            <div class="relative" data-controller="dropdown" data-dropdown-hover-value="true" data-action="mouseenter->dropdown#mouseEnter mouseleave->dropdown#mouseLeave">
              <button type="button" data-dropdown-target="trigger" data-action="click->dropdown#toggle" class="inline-flex items-center gap-1 <%= controller_name.include?('monitoring') ? 'text-gray-900 font-semibold' : 'text-gray-600 hover:text-gray-900' %>">
                Monitoring
                <svg class="w-4 h-4 transition-transform" data-dropdown-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="hidden absolute left-0 top-full mt-1 w-48 bg-white rounded-lg shadow-lg border border-gray-200 py-2 z-50" data-dropdown-target="panel">
                <%= link_to "Radar", admin_radar_monitorings_path, class: "block px-4 py-2 text-sm #{current_page?(admin_radar_monitorings_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" %>
                <%= link_to "Satellites", admin_satellite_monitorings_path, class: "block px-4 py-2 text-sm #{current_page?(admin_satellite_monitorings_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" %>
                <%= link_to "Radio Polls", admin_radio_poll_monitorings_path, class: "block px-4 py-2 text-sm #{current_page?(admin_radio_poll_monitorings_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" %>
                <%= link_to "Weather Stations", admin_weather_station_monitorings_path, class: "block px-4 py-2 text-sm #{current_page?(admin_weather_station_monitorings_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" %>
                <%= link_to "Lightnings", admin_lightning_monitorings_path, class: "block px-4 py-2 text-sm #{current_page?(admin_lightning_monitorings_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" %>
              </div>
            </div>
            <%= link_to "Back to site", root_path, class: "text-gray-600 hover:text-gray-900 text-sm" %>
          </div>
          <div class="hidden sm:flex items-center space-x-4">
            <%= link_to edit_admin_profile_path, class: "flex items-center gap-2 text-gray-600 hover:text-gray-900 text-sm" do %>
              <% if current_user.profile_image.attached? %>
                <%= image_tag current_user.profile_image, class: "w-8 h-8 rounded-full object-cover border border-gray-200" %>
              <% else %>
                <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center text-xs font-semibold"><%= current_user.first_name&.first %><%= current_user.last_name&.first %></span>
              <% end %>
              <span class="truncate max-w-[200px]"><%= current_user.email_address %></span>
            <% end %>
            <%= button_to "Logout", admin_logout_path, method: :delete, class: "text-red-600 hover:text-red-800" %>
          </div>
          <div class="flex sm:hidden items-center justify-between w-full">
            <%= button_to "Pretemp - Admin", admin_root_path, method: :get, class: "text-gray-900 font-semibold text-sm cursor-pointer" %>
            <button type="button" data-action="dropdown#toggle" class="p-2 text-gray-600 hover:text-gray-900">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
      <div class="hidden sm:hidden border-t border-gray-200" data-dropdown-target="panel">
        <div class="px-4 py-3 space-y-2">
          <%= link_to "Dashboard", admin_root_path, class: "block px-3 py-2 rounded-lg text-sm #{current_page?(admin_root_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50'}" %>
          <%= link_to "Invitations", admin_invitations_path, class: "block px-3 py-2 rounded-lg text-sm #{current_page?(admin_invitations_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50'}" %>
          <%= link_to "Forecasts", admin_forecasts_path, class: "block px-3 py-2 rounded-lg text-sm #{current_page?(admin_forecasts_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50'}" %>
          <%= link_to "Articles", admin_articles_path, class: "block px-3 py-2 rounded-lg text-sm #{current_page?(admin_articles_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50'}" %>
          <div data-controller="dropdown">
            <button type="button" data-dropdown-target="trigger" data-action="click->dropdown#toggle" class="flex items-center justify-between w-full px-3 py-2 rounded-lg text-sm <%= controller_name.include?('monitoring') ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50' %>">
              Monitoring
              <svg class="w-4 h-4 transition-transform" data-dropdown-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="hidden pl-4 space-y-1 mt-1" data-dropdown-target="panel">
              <%= link_to "Radar", admin_radar_monitorings_path, class: "block px-3 py-2 rounded-lg text-sm #{current_page?(admin_radar_monitorings_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50'}" %>
              <%= link_to "Satellites", admin_satellite_monitorings_path, class: "block px-3 py-2 rounded-lg text-sm #{current_page?(admin_satellite_monitorings_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50'}" %>
              <%= link_to "Radio Polls", admin_radio_poll_monitorings_path, class: "block px-3 py-2 rounded-lg text-sm #{current_page?(admin_radio_poll_monitorings_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50'}" %>
              <%= link_to "Weather Stations", admin_weather_station_monitorings_path, class: "block px-3 py-2 rounded-lg text-sm #{current_page?(admin_weather_station_monitorings_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50'}" %>
              <%= link_to "Lightnings", admin_lightning_monitorings_path, class: "block px-3 py-2 rounded-lg text-sm #{current_page?(admin_lightning_monitorings_path) ? 'text-gray-900 font-semibold bg-gray-100' : 'text-gray-600 hover:bg-gray-50'}" %>
            </div>
          </div>
        </div>
        <div class="px-4 py-3 border-t border-gray-200 flex justify-between items-center">
          <%= link_to edit_admin_profile_path, class: "flex items-center gap-2 text-gray-600 hover:text-gray-900 text-sm" do %>
            <% if current_user.profile_image.attached? %>
              <%= image_tag current_user.profile_image, class: "w-8 h-8 rounded-full object-cover border border-gray-200" %>
            <% else %>
              <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center text-xs font-semibold"><%= current_user.first_name&.first %><%= current_user.last_name&.first %></span>
            <% end %>
            <span class="truncate"><%= current_user.email_address %></span>
          <% end %>
          <%= button_to "Logout", admin_logout_path, method: :delete, class: "text-red-600 hover:text-red-800 text-sm" %>
        </div>
      </div>
    </nav>
    <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
      <% if flash[:notice] %>
        <div class="mb-4 p-4 bg-green-100 border border-green-300 text-green-800 rounded-lg">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="mb-4 p-4 bg-red-100 border border-red-300 text-red-800 rounded-lg">
          <%= flash[:alert] %>
        </div>
      <% end %>
      <%= yield %>
    </main>
    <div id="modals"></div>
  </body>
</html>
