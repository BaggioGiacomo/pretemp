<!DOCTYPE html>
<html>
  <head>
    <title>Pretemp - Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag "favicon.png", type: "image/png" %>
  </head>
  <body class="admin-ui min-h-screen flex items-center justify-center">
    <div class="admin-noise"></div>
    <div class="admin-glow admin-glow--one"></div>
    <div class="admin-glow admin-glow--two"></div>
    <div class="relative w-full max-w-md p-8">
      <% if flash[:notice] %>
        <div class="admin-flash admin-flash-notice mb-4 p-4 rounded-xl">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="admin-flash admin-flash-alert mb-4 p-4 rounded-xl">
          <%= flash[:alert] %>
        </div>
      <% end %>
      <%= yield %>
    </div>
  </body>
</html>
