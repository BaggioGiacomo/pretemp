<section class="relative overflow-hidden border-b border-slate-800 bg-linear-to-b from-slate-950 via-slate-950 to-slate-900">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(56,189,248,.18),transparent_55%),radial-gradient(circle_at_bottom,rgba(250,204,21,.12),transparent_55%)]"></div>
  <div class="relative max-w-6xl mx-auto px-4 py-6 md:py-16">
    <div class="space-y-6 max-w-3xl">
      <p class="inline-flex items-center rounded-full border border-sky-500/40 bg-slate-950/70 px-3 py-1 text-xs font-medium text-sky-200 shadow-sm shadow-sky-500/20">
        Contatti
      </p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight section-heading-accent">
        Contattaci
      </h1>
      <p class="text-sm md:text-base text-slate-300">
        Per informazioni, collaborazioni o segnalazioni, puoi contattare il gruppo PRETEMP o i singoli membri tramite i seguenti indirizzi email.
      </p>
    </div>
  </div>
</section>
<section class="max-w-6xl mx-auto px-4 py-10 md:py-12">
  <div class="space-y-6">
    <div class="rounded-2xl border border-slate-800 bg-slate-900/80 p-4 md:p-6 space-y-4">
      <h2 class="text-lg md:text-xl font-semibold tracking-tight section-heading-accent">Il gruppo Pretemp</h2>
      <p class="text-sm text-slate-300">Da usare preferibilmente:</p>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-sky-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <a href="mailto:info@pretemp.it" class="text-sm text-sky-300 hover:text-sky-200 hover:underline transition-colors">info@pretemp.it</a>
      </div>
    </div>
    <div class="rounded-2xl border border-slate-800 bg-slate-900/80 p-4 md:p-6 space-y-4">
      <h2 class="text-lg md:text-xl font-semibold tracking-tight section-heading-accent">Previsioni sperimentali e analisi dati</h2>
      <p class="text-sm text-slate-300">Indirizzi personali:</p>
      <ul class="space-y-2">
        <% [
          "nicola.carlon@pretemp.it",
          "francesco.demartin@pretemp.it",
          "mattia.nordio@pretemp.it",
          "giorgio.rotunno@pretemp.it",
          "pierluigi.randi@pretemp.it"
        ].each do |email| %>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-sky-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:<%= email %>" class="text-sm text-sky-300 hover:text-sky-200 hover:underline transition-colors"><%= email %></a>
          </li>
        <% end %>
      </ul>
    </div>
    <div class="rounded-2xl border border-slate-800 bg-slate-900/80 p-4 md:p-6 space-y-4">
      <h2 class="text-lg md:text-xl font-semibold tracking-tight section-heading-accent">Gestione database Storm Report e verifica previsioni</h2>
      <p class="text-sm text-slate-300">Indirizzi personali:</p>
      <ul class="space-y-2">
        <% [
          "federico.pavan@pretemp.it",
          "luca.valentini@pretemp.it",
          "nicola.carlon@pretemp.it"
        ].each do |email| %>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-sky-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:<%= email %>" class="text-sm text-sky-300 hover:text-sky-200 hover:underline transition-colors"><%= email %></a>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</section>