              <td class="px-6 py-4">Moneta da 2 euro</td>
              <td class="px-6 py-4">2.58 cm (stima di 2.5 cm)</td>
            </tr>
            <tr class="border-b border-slate-700/50">
              <td class="px-6 py-4">Pallina da ping pong</td>
