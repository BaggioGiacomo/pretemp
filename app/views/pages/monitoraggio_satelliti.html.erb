<section class="max-w-6xl mx-auto px-4 py-10 md:py-16">
  <div class="mb-8 md:mb-12">
    <h1 class="text-2xl md:text-3xl font-semibold tracking-tight section-heading-accent">Immagini satellitari</h1>
  </div>
  <div class="grid gap-3 sm:grid-cols md:grid-cols-2 lg:grid-cols-3">
    <% @satellite_monitorings.each do |satellite_monitoring| %>
      <%= link_to satellite_monitoring.url,
          class: "group relative overflow-hidden rounded-2xl border border-slate-800 bg-gradient-to-br from-slate-900 to-slate-900/40 p-5 flex items-center gap-3 hover:border-sky-500/60 hover:from-slate-800/80 hover:to-slate-900 hover:shadow-lg hover:shadow-sky-500/10 hover:-translate-y-0.5 transition-all duration-200", target: "_blank", rel: "noopener" do %>
        <span class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-sky-400/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></span>
        <span class="shrink-0 flex items-center justify-center w-10 h-10 rounded-xl bg-sky-500/10 text-sky-400 ring-1 ring-inset ring-sky-500/20 group-hover:bg-sky-500/20 group-hover:text-sky-300 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </span>
        <p class="flex-1 min-w-0 text-base font-semibold text-slate-100 group-hover:text-white truncate"><%= satellite_monitoring.name %></p>
        <span class="shrink-0 text-sky-400 group-hover:text-sky-300 group-hover:translate-x-1 transition-transform">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      <% end %>
    <% end %>
  </div>
</section>
